# Clonk - Environment Variables

# Contract address (set after deployment)
NEXT_PUBLIC_CLONK_CONTRACT=0x...

# App URL (Vercel deployment URL)
NEXT_PUBLIC_APP_URL=https://clonk.vercel.app

# Backend signer private key (generates claim signatures)
# Generate: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
CLAIM_SIGNER_PRIVATE_KEY=0x...
